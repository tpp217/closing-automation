# closing-automation 環境変数テンプレート（値は空。実値は Doppler / Vercel で管理）
# ローカルに .env / .env.local は置かない方針。動作確認は Vercel プレビューで行う。

# ── Supabase（service_role：サーバー専用。ブラウザに渡さない） ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# anon / publishable キー（公開可）。単体版（STANDALONE）のローカルログインで
# ブラウザの supabase-js が signInWithPassword に使う。SUPABASE_ANON_KEY を優先し、
# 無ければ SUPABASE_PUBLISHABLE_KEY を使う（新旧キー形式の両対応）。
# ※プラットフォーム版（STANDALONE 未設定）では未設定で構わない（使われない）。
SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=

# ── 既存：LINE SSO ログイン（HMAC Cookie セッション） ──
SESSION_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# ログイン許可する LINE userId（カンマ区切り）
ALLOWED_LINE_USER_IDS=

# ── F5：workspace-hub JWT 認証ゲート（既定は監視モード・非破壊） ──
# AUTH_ENFORCE: 未設定 / "off" なら監視のみ（現挙動を変えない・ログのみ）。
#               "on" にすると Bearer JWT の検証失敗・欠如・システム不一致を 401/403 でブロック。
#               ※ enforce 前に workspace-hub 側で当該テナントの system_access に
#                 system_key='closing' が付与済みか必ず確認すること。
AUTH_ENFORCE=
# JWKS エンドポイント（既定: https://auth.utinc.dev/.well-known/jwks.json）
JWKS_URL=
# 自アプリのシステムキー（既定: closing）。workspace-hub の SYSTEM_CATALOG キーと一致させる。
AUTH_SYSTEM_KEY=
# 期待する JWT 発行者 iss（既定: https://auth.utinc.dev）。署名検証に加えて iss を照合し、
# 別 issuer のトークンによるなりすましを弾く。既定値で運用するため通常は設定不要。
AUTH_EXPECTED_ISSUER=

# ── 単体販売版（STANDALONE）モード ──
# 未設定＝プラットフォーム版（既定・現状挙動を一切変えない・wh SSO ログイン）。
# STANDALONE: "true"/"1"/"on"/"yes" で単体版に切替。効果:
#   - wh SSO/JWT 監視ゲートを無効化（auth-gate.evaluateAuth が常に通す）。
#     ※単体版は wh JWT を持たないため。AUTH_ENFORCE=on 併用時の自前 API 401 を防ぐ。
#   - フロントの SSO 自動リダイレクト（/api/auth/login=SSO）を抑止し、認証アイコンを自前側へ向ける。
#   ※単体版の自前ログイン（/login）は未整備（要実装）。現状はフラグ/ゲート分岐/アイコン/
#     テナント固定までを用意し、ログイン本体は別途実装する。
STANDALONE=
# 単体版の固定テナント UUID。wh JWT が無くてもこの値でテナント分離コードが成立する
# （単一顧客＝1 テナント）。STANDALONE=true のとき必須（未設定だと業務 API が 500 で fail-closed）。
STANDALONE_TENANT_ID=
#
# ── 単体版のローカルログイン（Supabase Auth: email/password） ──
# 単体版は wh SSO を使わず、Supabase Auth でログインする：
#   /login（login.html）→ supabase-js が signInWithPassword で access_token を取得
#   → /api/auth/standalone-login がサーバー側で token を検証し closing_session を発行
#   → evaluateAuth（STANDALONE 分岐）が closing_session を必須にしてアクセスを保護。
# 必要 env: SUPABASE_URL（既存）＋ SUPABASE_ANON_KEY（上記・公開可）。
# 初期ユーザーは **Supabase ダッシュボードで手動作成**する（このアプリは自動作成しない）：
#   Supabase → Authentication → Users → Add user（email + password）。
#   ※招待制運用のため自己サインアップは想定しない。
