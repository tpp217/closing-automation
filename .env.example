# closing-automation 環境変数テンプレート（値は空。実値は Doppler / Vercel で管理）
# ローカルに .env / .env.local は置かない方針。動作確認は Vercel プレビューで行う。

# ── Supabase（service_role：サーバー専用。ブラウザに渡さない） ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── 既存：LINE SSO ログイン（HMAC Cookie セッション） ──
SESSION_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# ログイン許可する LINE userId（カンマ区切り）
ALLOWED_LINE_USER_IDS=

# ── F5：workspace-hub JWT 認証ゲート（既定は監視モード・非破壊） ──
# AUTH_ENFORCE: 未設定 / "off" なら監視のみ（現挙動を変えない・ログのみ）。
#               "on" にすると Bearer JWT の検証失敗・欠如・システム不一致を 401/403 でブロック。
#               ※ enforce 前に workspace-hub 側で当該テナントの system_access に
#                 system_key='closing' が付与済みか必ず確認すること。
AUTH_ENFORCE=
# JWKS エンドポイント（既定: https://auth.utinc.dev/.well-known/jwks.json）
JWKS_URL=
# 自アプリのシステムキー（既定: closing）。workspace-hub の SYSTEM_CATALOG キーと一致させる。
AUTH_SYSTEM_KEY=
